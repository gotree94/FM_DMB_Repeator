#==============================================================================
# SPI2 — FPGA Control Interface
# Mode: Master, Full-Duplex
# Frame: 8-bit, MSB first
# Polarity: LOW (CPOL=0), Phase: 1EDGE (CPHA=0)
# Prescaler: 4 → 11.25 MHz (45 MHz / 4)
#==============================================================================
SPI2.BaudRatePrescaler=SPI_BAUDRATEPRESCALER_4
SPI2.CLKPhase=SPI_PHASE_1EDGE
SPI2.CLKPolarity=SPI_POLARITY_LOW
SPI2.CRCCalculation=SPI_CRCCALCULATION_DISABLE
SPI2.CRCPolynomial=7
SPI2.DataSize=SPI_DATASIZE_8BIT
SPI2.Direction=SPI_DIRECTION_2LINES
SPI2.FirstBit=SPI_FIRSTBIT_MSB
SPI2.Frequency=11250000
SPI2.Freq=11250000
SPI2.IPParameters=BaudRatePrescaler,CLKPhase,CLKPolarity,CRCCalculation,CRCPolynomial,DataSize,Direction,FirstBit,Frequency,Mode,NSS,NSSPMode,TimBreak
SPI2.Mode=SPI_MODE_MASTER
SPI2.NSS=SPI_NSS_SOFT
SPI2.NSSPMode=SPI_NSS_POL_LOW
SPI2.TimBreak=SPI_TIMBREAK_DISABLE

#==============================================================================
# USART3 — CLI Debug Console
# Mode: Asynchronous, 115200 8N1
# HW Flow Control: None
#==============================================================================
USART3.BaudRate=115200
USART3.HwFlowCtl=UART_HWCONTROL_NONE
USART3.IPParameters=BaudRate,HwFlowCtl,Mask,RxPin,TxPin,WordLength
USART3.Mask=0x0
USART3.RxPin=PD9
USART3.TxPin=PD8
USART3.WordLength=UART_WORDLENGTH_8B

#==============================================================================
# TIM6 — Sensor Polling Timer (100 ms interrupt)
# Prescaler: 18000-1 (180 MHz / 18000 = 10 kHz)
# Period: 1000-1 (10 kHz / 1000 = 10 Hz = 100 ms)
#==============================================================================
TIM6.AutoReloadPreload=TIM_AUTORELOAD_PRELOAD_DISABLE
TIM6.IPParameters=AutoReloadPreload,Prescaler,Period
TIM6.Prescaler=18000
TIM6.Period=1000

#==============================================================================
# GPIO Configuration
#==============================================================================
# PD7 — SPI2 CS (Output, Push-Pull, High)
PD7.GPIOParameters=GPIO_Label
PD7.GPIO_Label=SPI2_CS
PD7.Locked=true
PD7.Signal=GPIO_Output

# PD8 — USART3 TX (Alternate Function AF7)
PD8.Locked=true
PD8.Signal=USART3_TX

# PD9 — USART3 RX (Alternate Function AF7)
PD9.Locked=true
PD9.Signal=USART3_RX

# PB13 — SPI2 SCK (Alternate Function AF5)
PB13.Locked=true
PB13.Signal=SPI2_SCK

# PB14 — SPI2 MISO (Alternate Function AF5)
PB14.Locked=true
PB14.Signal=SPI2_MISO

# PB15 — SPI2 MOSI (Alternate Function AF5)
PB15.Locked=true
PB15.Signal=SPI2_MOSI

# PG13 — Green LED (Output)
PG13.GPIOParameters=GPIO_Label
PG13.GPIO_Label=LED_GREEN
PG13.Locked=true
PG13.Signal=GPIO_Output

# PH0/PH1 — HSE Oscillator
PH0.Locked=true
PH0.Signal=RCC_OSC_IN
PH1.Locked=true
PH1.Signal=RCC_OSC_OUT

#==============================================================================
# NVIC — Interrupt Priorities
#==============================================================================
NVIC.PriorityGroup=NVIC_PRIORITYGROUP_4
NVIC.TIM6_DAC_IRQn=0,0
NVIC.TIM6_DAC_IRQn.Locked=true
NVIC.TIM6_DAC_IRQn.preemptionPriority=5
NVIC.TIM6_DAC_IRQn.subPriority=0

